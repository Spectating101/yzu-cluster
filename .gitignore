logs/
*.log
*.pid
*.bak
*.tmp
*.old
*.orig

# SQLite runtime sidecars
*.sqlite-wal
*.sqlite-shm
*.sqlite3-wal
*.sqlite3-shm
*.db-wal
*.db-shm

