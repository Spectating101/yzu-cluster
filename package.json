{
  "name": "yzu-cluster",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "dev:legacy": "vite --host 127.0.0.1 --open /index-legacy.html",
    "test:v2-parity": "mkdir -p .tmp-pw && TMPDIR=$PWD/.tmp-pw playwright test e2e/v2-parity.spec.js",
    "test:v2": "mkdir -p .tmp-pw && TMPDIR=$PWD/.tmp-pw playwright test e2e/v2-parity.spec.js e2e/v2-discover.spec.js e2e/v2-cluster.spec.js e2e/v2-resources.spec.js",
    "build": "vite build",
    "build:faculty": "bash scripts/build_faculty_ui.sh",
    "preview": "vite preview --host 127.0.0.1",
    "test:e2e": "YZU_DESK_URL=http://127.0.0.1:5178 playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:ui-contract": "playwright test e2e/ui-contract.spec.js",
    "preview:desk": "node scripts/rd_preview_page.mjs",
    "sync:yzu-cluster": "bash scripts/sync_yzu_cluster_github.sh"
  },
  "dependencies": {
    "@radix-ui/react-separator": "^1.1.10",
    "@radix-ui/react-slot": "^1.3.0",
    "@radix-ui/react-tabs": "^1.1.15",
    "@radix-ui/react-tooltip": "^1.2.10",
    "@tailwindcss/vite": "^4.3.1",
    "@vitejs/plugin-react": "^4.4.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.21.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.1",
    "tailwindcss-animate": "^1.0.7",
    "vite": "^6.3.5"
  },
  "devDependencies": {
    "@playwright/test": "^1.52.0"
  }
}
