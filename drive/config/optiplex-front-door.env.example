# Copy to ~/.config/research-drive/front-door.env on the Optiplex.
# Keep the real file outside git and chmod 600 it.

# Public UI authority checkout and exact first-release SHA.
YZU_PUBLIC_REPO=/absolute/path/to/yzu-cluster
YZU_PUBLIC_SHA=794c1f3035e0a158e4f9b401e0686609cab1c6b3

# Bind only to the Optiplex Tailscale address for the first release.
YZU_DESK_HOST=100.x.y.z
YZU_DESK_PORT=8765
YZU_DESK_SERVE_UI=true
# Optional override; default is ${YZU_PUBLIC_REPO}/dist in the launcher.
# YZU_DESK_STATIC_DIR=/absolute/path/to/yzu-cluster/dist

# Keep unset for the same-origin internal release. A future gateway may set one
# exact http(s) origin; wildcard CORS is rejected.
# YZU_DESK_CORS_ORIGIN=https://future-gateway.example

# Canonical private registry. Relative values resolve from private repo root.
# For a split front-door checkout + runtime-integration store, point this at the
# runtime authority file (or symlink drive/config/research_query_registry.json to it)
# so promotions from windows workers appear in Library/query without receipt_only drift.
SHARPE_REGISTRY_PATH=drive/config/research_query_registry.json

# When set, link_front_door_host_config.sh also binds registry + data_lake/procured
# (and data_lake/yzu_cluster if missing) to this runtime drive root.
# YZU_RUNTIME_DRIVE_ROOT=/absolute/path/to/Sharpe-Renaissance-runtime-integration/drive

# Required to protect material desk writes. Generate a strong random value.
YZU_DESK_ACCESS_TOKEN=replace-with-secret

# Composer / procurement secrets required by the enabled private capabilities.
CURSOR_API_KEY=replace-with-secret
# TAVILY_API_KEY=replace-with-secret
# DATACITE_EMAIL=replace-if-required

# Python interpreter for the front door. Must provide cursor_sdk when Composer is enabled
# (e.g. Sharpe-Renaissance/.venv/bin/python). System python3 alone reports Composer
# configured via CURSOR_API_KEY then fails Ask with ModuleNotFoundError.
YZU_PYTHON_BIN=/absolute/path/to/venv/bin/python

# Worker-control plane is separate (Tailscale :8780). Keep YZU_WORKER_CONTROL_TOKEN
# identical on the controller process and each Windows worker token file, or join returns 401.
